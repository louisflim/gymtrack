## Copy to local.properties (gitignored) and adjust.

sdk.dir=C\:\\Users\\YOUR_NAME\\AppData\\Local\\Android\\Sdk

# Backend base URL used by Retrofit (must end with /).
#
# Android emulator → host machine:
debug.base.url=http://10.0.2.2:8080/
#
# Physical phone on same Wi-Fi → your PC IPv4 (ipconfig):
# debug.base.url=http://192.168.x.x:8080/
#
# Deployed API (release / HTTPS):
release.base.url=https://YOUR-API-HOST/
