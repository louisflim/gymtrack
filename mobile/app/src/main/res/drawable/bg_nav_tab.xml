<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/gymtrack_accent" />
            <stroke android:width="1dp" android:color="@color/gymtrack_accent" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/gymtrack_background" />
            <stroke android:width="1dp" android:color="@color/gymtrack_border" />
        </shape>
    </item>
</selector>
