<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GymTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/gymtrack_background</item>
        <item name="android:statusBarColor">@color/gymtrack_background</item>
        <item name="android:navigationBarColor">@color/gymtrack_background</item>
        <item name="colorPrimary">@color/gymtrack_accent</item>
        <item name="colorOnPrimary">@color/gymtrack_background</item>
        <item name="android:textColorPrimary">@color/gymtrack_text_primary</item>
        <item name="android:textColorSecondary">@color/gymtrack_text_muted</item>
    </style>

    <style name="Widget.GymTrack.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/gymtrack_accent</item>
        <item name="android:textColor">@color/gymtrack_background</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <style name="Widget.GymTrack.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/gymtrack_border</item>
        <item name="android:textColor">@color/gymtrack_text_primary</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <style name="Widget.GymTrack.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gymtrack_border</item>
        <item name="hintTextColor">@color/gymtrack_text_muted</item>
        <item name="android:textColorHint">@color/gymtrack_placeholder</item>
    </style>

    <style name="TextAppearance.GymTrack" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/gymtrack_text_primary</item>
    </style>

    <style name="TextAppearance.GymTrack.Eyebrow">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.25</item>
        <item name="android:textColor">@color/gymtrack_text_muted</item>
    </style>

    <style name="TextAppearance.GymTrack.Heading">
        <item name="android:textSize">28sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/gymtrack_text_primary</item>
    </style>

    <style name="TextAppearance.GymTrack.HeroLine">
        <item name="android:textSize">40sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/gymtrack_text_primary</item>
    </style>

    <style name="TextAppearance.GymTrack.SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:textColor">@color/gymtrack_text_muted</item>
    </style>
</resources>
