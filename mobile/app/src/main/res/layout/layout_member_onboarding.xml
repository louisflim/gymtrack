<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_section_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/onboardingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.GymTrack.SectionLabel"
        android:textColor="@color/gymtrack_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/onboardingBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gymtrack_text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/onboardingGym"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gymtrack_text_muted"
        android:textSize="14sp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/scanGymButton"
        style="@style/Widget.GymTrack.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Scan Gym QR Code"
        android:visibility="gone" />

    <TextView
        android:id="@+id/onboardingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gymtrack_accent"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
