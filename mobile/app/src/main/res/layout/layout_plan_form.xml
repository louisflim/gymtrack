<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_section_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/planFormTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CREATE PLAN"
        android:textAppearance="@style/TextAppearance.GymTrack.SectionLabel" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.GymTrack.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Plan Name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/planNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/gymtrack_text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.GymTrack.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Duration (days)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/planDurationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/gymtrack_text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.GymTrack.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Price (PHP)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/planPriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/gymtrack_text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/savePlanButton"
        style="@style/Widget.GymTrack.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Create Plan" />

    <TextView
        android:id="@+id/planFormStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gymtrack_accent"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
