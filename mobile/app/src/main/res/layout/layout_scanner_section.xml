<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_section_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCAN MEMBER QR"
        android:textAppearance="@style/TextAppearance.GymTrack.SectionLabel" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Scan a member QR code for check-in or check-out."
        android:textColor="@color/gymtrack_text_muted"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openScannerButton"
        style="@style/Widget.GymTrack.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open QR Scanner" />

    <TextView
        android:id="@+id/scanStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gymtrack_accent"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
