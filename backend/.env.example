# GymTrack backend environment variables
# Copy to `.env` for reference, then set these in your OS / IDE / host.
# Spring Boot reads OS environment variables automatically (it does not load .env files by itself).

# --- Required: database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_HOST:6543/postgres?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=postgres.YOUR_PROJECT_REF
SPRING_DATASOURCE_PASSWORD=YOUR_PASSWORD

# --- Required: auth ---
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION=86400000

# --- PayMongo (leave empty + MOCK for school demos) ---
PAYMONGO_MOCK_ENABLED=true
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
# APP_WEB_BASE_URL=http://localhost:5173
# PAYMONGO_SUCCESS_URL=
# PAYMONGO_CANCEL_URL=

# --- Optional ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# SPRING_PROFILES_ACTIVE=prod
