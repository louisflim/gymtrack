# Copy to application-local.properties (gitignored) or set these as environment variables.
# Use TEST keys for local development; use LIVE keys only in production.

# Database (optional — defaults are in application.properties)
# spring.datasource.url=jdbc:postgresql://YOUR_HOST:5432/postgres
# spring.datasource.username=postgres.YOUR_PROJECT
# spring.datasource.password=YOUR_PASSWORD
#
# If spring-boot:run fails with "Unable to determine Dialect", the app cannot reach
# PostgreSQL. Check internet, Supabase project status, and that empty env vars like
# SPRING_DATASOURCE_URL are not overriding your credentials.

# ---------------------------------------------------------------------------
# Local development (mock checkout — no PayMongo account required)
# ---------------------------------------------------------------------------
paymongo.mock-enabled=true

# ---------------------------------------------------------------------------
# PayMongo test mode (real checkout UI, test cards/wallets)
# ---------------------------------------------------------------------------
# paymongo.secret-key=sk_test_YOUR_TEST_SECRET_KEY
# paymongo.public-key=pk_test_YOUR_TEST_PUBLIC_KEY
# paymongo.mock-enabled=false
# paymongo.success-url=http://localhost:5173/payment/success
# paymongo.cancel-url=http://localhost:5173/payment/cancel
# paymongo.webhook-secret=whsec_YOUR_TEST_WEBHOOK_SECRET

# ---------------------------------------------------------------------------
# Production deployment (set on your host — never commit live keys)
# ---------------------------------------------------------------------------
# PAYMONGO_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY
# PAYMONGO_PUBLIC_KEY=pk_live_YOUR_LIVE_PUBLIC_KEY
# PAYMONGO_MOCK_ENABLED=false
# PAYMONGO_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET
# PAYMONGO_SUCCESS_URL=https://your-frontend.com/payment/success
# PAYMONGO_CANCEL_URL=https://your-frontend.com/payment/cancel
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# PayMongo dashboard setup (production):
# 1. Developers → API keys → copy live secret key
# 2. Developers → Webhooks → add endpoint:
#    POST https://your-backend.com/api/payments/webhook
#    Events: checkout.session.payment.paid (and/or payment.paid)
# 3. Copy the webhook signing secret into PAYMONGO_WEBHOOK_SECRET
# 4. Set success/cancel URLs to your deployed web app routes
