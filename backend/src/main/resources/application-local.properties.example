# Local Spring config (gitignored). Prefer environment variables.
# Copy from application.properties.example, then either:
#   1) Set env vars (recommended), or
#   2) Uncomment and fill the values below for local-only use.
#
# Required for DB + JWT:
#   SPRING_DATASOURCE_URL
#   SPRING_DATASOURCE_USERNAME
#   SPRING_DATASOURCE_PASSWORD
#   JWT_SECRET
#
# PayMongo (optional when paymongo.mock-enabled=true):
#   PAYMONGO_SECRET_KEY
#   PAYMONGO_PUBLIC_KEY
#   PAYMONGO_WEBHOOK_SECRET

# spring.datasource.url=jdbc:postgresql://YOUR_HOST:6543/postgres?sslmode=require&prepareThreshold=0
# spring.datasource.username=postgres.YOUR_PROJECT_REF
# spring.datasource.password=YOUR_PASSWORD
# jwt.secret=local-dev-secret-at-least-32-characters-long

paymongo.mock-enabled=true
